# ============================================================
# CONFIG
# ============================================================

load_config() {
    [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"
    AUTO_DETECT=${AUTO_DETECT:-"true"}
    AUTO_CRONTAB=${AUTO_CRONTAB:-"true"}
    AUTO_UPDATE_HOST=${AUTO_UPDATE_HOST:-"true"}
    AUTO_UPDATE_LXC=${AUTO_UPDATE_LXC:-"true"}
    AUTO_BACKUP=${AUTO_BACKUP:-"true"}
    AUTO_HEALTH=${AUTO_HEALTH:-"true"}
}

save_config() {
    cat > "$CONFIG_FILE" << CONF
AUTO_DETECT=${AUTO_DETECT}
AUTO_CRONTAB=${AUTO_CRONTAB}
AUTO_UPDATE_HOST=${AUTO_UPDATE_HOST}
AUTO_UPDATE_LXC=${AUTO_UPDATE_LXC}
AUTO_BACKUP=${AUTO_BACKUP}
AUTO_HEALTH=${AUTO_HEALTH}
CONF
    chmod 600 "$CONFIG_FILE"
}

# ============================================================
# PERMISSIONS & VALIDATION
# ============================================================

ensure_permissions() {
    [[ -f "$SERVICES_FILE" ]] && chmod 600 "$SERVICES_FILE" 2>/dev/null
    [[ -f "$CONFIG_FILE" ]] && chmod 600 "$CONFIG_FILE" 2>/dev/null
}

validate_input() {
    echo "$1" | grep -qE "^[a-zA-Z0-9._/| =-]+$"
}

# ============================================================
# LOGGING
# ============================================================

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"; }
log_info() { log "[INFO] $1"; }
log_ok() { log "[OK] $1"; }
log_warn() { log "[WARN] $1"; }
log_error() { log "[ERROR] $1"; }

# ============================================================
# FEATURE 1: AUTO-UPDATE SCRIPT
# ============================================================

get_remote_version() {
    curl -fsSL "${GITHUB_RAW}/smart-update" 2>/dev/null | grep "^VERSION=" | cut -d'"' -f2
}

update_script() {
    echo "$(msg update_script_title)"
    echo "$(msg update_script_current): v${VERSION}"

    local remote_version
    remote_version=$(get_remote_version)

    if [[ -z "$remote_version" ]]; then
        echo "  [ERROR] Cannot check GitHub"
        return 1
    fi

    echo "$(msg update_script_latest): v${remote_version}"

    if [[ "$remote_version" == "$VERSION" ]]; then
        echo "$(msg update_script_ok)"
        return 0
    fi

    echo "$(msg update_script_need)"
    echo -n "  Downloading... "

    if curl -fsSL "${GITHUB_RAW}/smart-update" -o /usr/local/bin/smart-update; then
        chmod +x /usr/local/bin/smart-update
        echo "$(msg update_script_done)"
        echo "  Run 'smart-update' to use new version"
    else
        echo "[ERROR]"
        return 1
    fi
}

# ============================================================
# FEATURE 2: DRY RUN
# ============================================================

dryrun_host() {
    local updates
    updates=$(apt list --upgradable 2>/dev/null | grep -c "upgradable" || true)
    if [[ "$updates" -gt 0 ]]; then
        echo "  [HOST] ${updates} packages"
        apt list --upgradable 2>/dev/null | grep "upgradable" | head -10
    else
        echo "  [HOST] No updates"
    fi
}

dryrun_container() {
    local container=$1
    local name os
    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
    os=$(pct config "$container" | awk '/^ostype/ {print $2}')

    echo "  [CT ${container}] ${name} (${os})"

    # Check service updates
    if [[ -f "$SERVICES_FILE" ]]; then
        local entries
        entries=$(grep "^${container}|" "$SERVICES_FILE" 2>/dev/null || true)
        while IFS='|' read -r ct_id service cmd; do
            [[ "$ct_id" == "$container" ]] && echo "    - Service: ${service}"
        done <<< "$entries"
    fi
}

dryrun_update() {
    echo "$(msg dryrun_title)"
    echo ""
    echo "$(msg dryrun_will)"
    echo ""

    dryrun_host
    echo ""

    for container in $(pct list 2>/dev/null | awk '{if(NR>1) print $1}'); do
        dryrun_container "$container"
    done
}

# ============================================================
# FEATURE 3: HEALTH CHECK
# ============================================================

health_check() {
    echo "$(msg health_title)"
    echo ""

    # Host CPU
    local load
    load=$(cat /proc/loadavg | awk '{print $1}')
    local cores
    cores=$(nproc)
    local load_pct
    load_pct=$(echo "$load $cores" | awk '{printf "%.0f", ($1/$2)*100}')

    echo "$(msg health_host)"
    echo -n "$(msg health_cpu) "
    if [[ "$load_pct" -lt 70 ]]; then
        echo "${load} (${load_pct}%) $(msg health_status_ok)"
    elif [[ "$load_pct" -lt 90 ]]; then
        echo "${load} (${load_pct}%) $(msg health_status_warn)"
    else
        echo "${load} (${load_pct}%) $(msg health_status_crit)"
    fi

    # Host Memory
    local mem_total mem_used mem_pct
    mem_total=$(free -m | awk '/Mem:/{print $2}')
    mem_used=$(free -m | awk '/Mem:/{print $3}')
    mem_pct=$((mem_used * 100 / mem_total))

    echo -n "$(msg health_mem) "
    if [[ "$mem_pct" -lt 70 ]]; then
        echo "${mem_used}/${mem_total}MB (${mem_pct}%) $(msg health_status_ok)"
    elif [[ "$mem_pct" -lt 90 ]]; then
        echo "${mem_used}/${mem_total}MB (${mem_pct}%) $(msg health_status_warn)"
    else
        echo "${mem_used}/${mem_total}MB (${mem_pct}%) $(msg health_status_crit)"
    fi

    # Host Disk
    local disk_pct
    disk_pct=$(df / | awk 'NR==2{print $5}' | tr -d '%')

    echo -n "$(msg health_disk) "
    if [[ "$disk_pct" -lt 70 ]]; then
        echo "${disk_pct}% $(msg health_status_ok)"
    elif [[ "$disk_pct" -lt 90 ]]; then
        echo "${disk_pct}% $(msg health_status_warn)"
    else
        echo "${disk_pct}% $(msg health_status_crit)"
    fi

    echo ""

    # LXC Containers
    echo "LXC Containers:"
    for container in $(pct list 2>/dev/null | awk '{if(NR>1) print $1}'); do
        local name status
        name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
        status=$(pct status "$container" 2>/dev/null | awk '{print $2}')

        if [[ "$status" == "running" ]]; then
            # Check container load
            local ct_load
            ct_load=$(pct exec "$container" -- cat /proc/loadavg 2>/dev/null | awk '{print $1}' || echo "0")
            echo -n "  CT ${container} (${name}): ${status} load=${ct_load} "
        else
            echo -n "  CT ${container} (${name}): ${status} "
        fi

        # Quick health assessment
        if [[ "$status" == "stopped" ]]; then
            echo "$(msg health_status_warn)"
        elif [[ "${ct_load:-0}" > "2.0" ]]; then
            echo "$(msg health_status_warn)"
        else
            echo "$(msg health_status_ok)"
        fi
    done
}

# ============================================================
# FEATURE 4: DOCKER/PODMAN UPDATES
# ============================================================

detect_containers() {
    local container=$1
    local result=""

    # Check for Podman
    if pct exec "$container" -- which podman &>/dev/null; then
        result=$(pct exec "$container" -- podman ps --format "{{.Names}}" 2>/dev/null || true)
    # Check for Docker
    elif pct exec "$container" -- which docker &>/dev/null; then
        result=$(pct exec "$container" -- docker ps --format "{{.Names}}" 2>/dev/null || true)
    fi

    echo "$result"
}

update_containers() {
    local container=$1
    local engine=""

    # Detect container engine
    if pct exec "$container" -- which podman &>/dev/null; then
        engine="podman"
    elif pct exec "$container" -- which docker &>/dev/null; then
        engine="docker"
    else
        return 0
    fi

    local containers
    containers=$(pct exec "$container" -- $engine ps --format "{{.Names}}" 2>/dev/null || true)

    if [[ -z "$containers" ]]; then
        return 0
    fi

    log_info "CT ${container}: Found ${engine} containers"

    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        log_info "CT ${container}: Pulling ${name}..."
        pct exec "$container" -- $engine pull "$name" >> "$LOG_FILE" 2>&1 || true
    done <<< "$containers"
}

# ============================================================
# FEATURE 5: BACKUP
# ============================================================

backup_lxc() {
    local container=$1
    local name
    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")

    mkdir -p "$BACKUP_DIR"

    local backup_file="${BACKUP_DIR}/ct_${container}_$(date +%Y%m%d_%H%M%S).tar.gz"

    log_info "Backing up CT ${container} (${name})..."

    # Backup config
    pct config "$container" > "${backup_file}.conf"

    # Backup using vzdump (PVE built-in)
    if command -v vzdump &>/dev/null; then
        vzdump "$container" --storage local --compress gzip --mode snapshot >> "$LOG_FILE" 2>&1
        log_ok "Backup CT ${container}: vzdump"
    else
        # Fallback: backup config only
        log_warn "CT ${container}: vzdump not available, config backed up only"
    fi
}

backup_all() {
    echo "$(msg backup_title)"
    echo ""
    echo "$(msg backup_create)"
    echo ""

    mkdir -p "$BACKUP_DIR"

    for container in $(pct list 2>/dev/null | awk '{if(NR>1) print $1}'); do
        backup_lxc "$container"
    done

    echo ""
    echo "$(msg backup_done)"
    ls -lh "$BACKUP_DIR"/*.conf 2>/dev/null | tail -5
}

# ============================================================
# UPDATE FUNCTIONS
# ============================================================

update_host() {
    log_info "=== Updating PVE Host ==="
    local updates
    updates=$(apt list --upgradable 2>/dev/null | grep -c "upgradable" || true)
    if [[ "$updates" -eq 0 ]]; then
        log_ok "Host: No updates available"
        return 0
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        echo "  [DRY RUN] Would update ${updates} packages"
        return 0
    fi

    log_info "Host: ${updates} packages to update"
    if apt-get update -qq && apt-get upgrade -y -qq >> "$LOG_FILE" 2>&1; then
        log_ok "Host: Update completed"
    else
        log_error "Host: Update failed"
        return 1
    fi
    [[ -f /var/run/reboot-required ]] && log_warn "Host: Reboot required"
    apt-get autoremove -y -qq >> "$LOG_FILE" 2>&1 || true
    apt-get autoclean -qq >> "$LOG_FILE" 2>&1 || true
}

update_container_os() {
    local container=$1
    local name os
    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
    os=$(pct config "$container" | awk '/^ostype/ {print $2}')

    if [[ "$DRY_RUN" == "true" ]]; then
        echo "  [DRY RUN] CT ${container} (${name}): Would update OS"
        return 0
    fi

    log_info "CT ${container} (${name}): Updating OS..."
    case "$os" in
    alpine) pct exec "$container" -- ash -c "apk update && apk upgrade" >> "$LOG_FILE" 2>&1 ;;
    archlinux) pct exec "$container" -- bash -c "pacman -Syyu --noconfirm" >> "$LOG_FILE" 2>&1 ;;
    fedora|rocky|centos|alma) pct exec "$container" -- bash -c "dnf -y update && dnf -y upgrade" >> "$LOG_FILE" 2>&1 ;;
    ubuntu|debian|devuan)
        pct exec "$container" -- bash -c "apt-get update && DEBIAN_FRONTEND=noninteractive apt-get -o Dpkg::Options::='--force-confold' dist-upgrade -y" >> "$LOG_FILE" 2>&1
        pct exec "$container" -- bash -c "rm -rf /usr/lib/python3.*/EXTERNALLY-MANAGED" 2>/dev/null || true
        ;;
    opensuse) pct exec "$container" -- bash -c "zypper ref && zypper --non-interactive dup" >> "$LOG_FILE" 2>&1 ;;
    *) log_warn "CT ${container}: Unknown OS '${os}'"; return 1 ;;
    esac

    case "$os" in
    ubuntu|debian|devuan) pct exec "$container" -- bash -c "apt-get autoremove -y && apt-get autoclean" >> "$LOG_FILE" 2>&1 || true ;;
    fedora|rocky|centos|alma) pct exec "$container" -- bash -c "dnf autoremove -y && dnf clean all" >> "$LOG_FILE" 2>&1 || true ;;
    esac
}

update_container_services() {
    local container=$1
    [[ ! -f "$SERVICES_FILE" ]] && return 0
    local entries
    entries=$(grep -v '^#' "$SERVICES_FILE" | grep -v '^$' | grep "^${container}|" || true)
    [[ -z "$entries" ]] && return 0
    while IFS='|' read -r ct_id service cmd; do
        if [[ "$ct_id" == "$container" ]]; then
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "  [DRY RUN] Would update service: ${service}"
            else
                log_info "CT ${container}: Updating '${service}'..."
                if eval "$cmd" >> "$LOG_FILE" 2>&1; then
                    log_ok "CT ${container}: '${service}' updated"
                else
                    log_error "CT ${container}: '${service}' update failed"
                fi
            fi
        fi
    done <<< "$entries"
}

update_container() {
    local container=$1
    local name
    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
    log_info "=== CT ${container} (${name}) ==="

    if pct config "$container" 2>/dev/null | grep -q "^template:"; then
        log_warn "CT ${container}: Skipping template"
        return 0
    fi

    local status
    status=$(pct status "$container" 2>/dev/null || echo "status: unknown")
    if [[ "$status" == "status: stopped" ]]; then
        if [[ "$DRY_RUN" == "true" ]]; then
            echo "  [DRY RUN] Would start CT ${container}"
        else
            log_info "CT ${container}: Starting..."
            pct start "$container" >> "$LOG_FILE" 2>&1
            sleep 5
        fi
    fi

    update_container_os "$container" || true
    update_container_services "$container"
    update_containers "$container" || true
}

# ============================================================
# SERVICE MANAGEMENT
# ============================================================

cmd_list() {
    echo -e "\n=== Service Update Entries ==="
    if [[ -f "$SERVICES_FILE" ]]; then
        local count=0
        while IFS='|' read -r ct_id service cmd; do
            [[ "$ct_id" =~ ^#.*$ || -z "$ct_id" ]] && continue
            echo "  CT ${ct_id} | ${service} | ${cmd}"
            count=$((count + 1))
        done < "$SERVICES_FILE"
        echo -e "\nTotal: ${count} entries"
    else
        echo "  No services.conf found"
    fi
}

cmd_add() {
    local ct_id="$1" service="$2" cmd="$3"
    [[ -z "$ct_id" || -z "$service" || -z "$cmd" ]] && { echo "Usage: smart-update --add <CT_ID> <SERVICE> \"<CMD>\""; exit 1; }
    validate_input "$ct_id" || { echo "Invalid Container ID"; exit 1; }
    validate_input "$service" || { echo "Invalid service name"; exit 1; }
    [[ -f "$SERVICES_FILE" ]] && sed -i "/^${ct_id}|${service}|/d" "$SERVICES_FILE"
    echo "${ct_id}|${service}|${cmd}" >> "$SERVICES_FILE"
    chmod 600 "$SERVICES_FILE"
    echo "Added: CT ${ct_id} | ${service}"
}

cmd_remove() {
    local ct_id="$1" service="$2"
    [[ -z "$ct_id" || -z "$service" ]] && { echo "Usage: smart-update --remove <CT_ID> <SERVICE>"; exit 1; }
    if [[ -f "$SERVICES_FILE" ]]; then
        sed -i "/^${ct_id}|${service}|/d" "$SERVICES_FILE"
        echo "Removed: CT ${ct_id} | ${service}"
    fi
}

detect_services() {
    local count=0
    echo "$(msg detect_title)"
    echo ""
    for container in $(pct list 2>/dev/null | awk '{if(NR>1) print $1}'); do
        local name os
        name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
        os=$(pct config "$container" 2>/dev/null | awk '/^ostype/ {print $2}')
        echo "CT ${container} (${name}) [${os}]"
        local services
        for svc in $services; do
        services=$(pct exec "$container" -- systemctl list-units --type=service --state=running --no-pager 2>/dev/null | grep -E "^\s+[a-z]" | grep -v "getty\|journald\|Network\|dbus\|rsyslog\|systemd-logind\|crond\|networkd\|logind\|user@\|\.mount\|\.socket\|\.timer\|\.path\|\.scope\|\.slice" | awk '{print $1}' | sed 's/\.service//' || true)
            [[ "$svc" =~ ^(ssh|postfix|cron|rsyslog)$ ]] && continue
            if grep -q "^${container}|${svc}|" "$SERVICES_FILE" 2>/dev/null; then
                echo "  - ${svc} (configured)"
                continue
            fi
            local update_cmd=""
            case "$os" in
                alma|centos|fedora|rocky) update_cmd="pct exec ${container} -- dnf update -y ${svc}" ;;
                ubuntu|debian|devuan) update_cmd="pct exec ${container} -- apt update && apt upgrade -y ${svc}" ;;
                alpine) update_cmd="pct exec ${container} -- apk update && apk upgrade ${svc}" ;;
            esac
            if [[ -n "$update_cmd" ]]; then
                echo "  + ${svc} (NEW)"
                echo "${container}|${svc}|${update_cmd}" >> "$SERVICES_FILE"
                count=$((count + 1))
            fi
        done
        echo ""
    done
    chmod 600 "$SERVICES_FILE" 2>/dev/null
    echo "$(msg detected) ${count} new services"
}

# ============================================================
# SETTINGS MENU
# ============================================================

show_settings() {
    while true; do
        clear
        echo "============================================"
        echo "  $(msg settings_title)"
        echo "============================================"
        echo ""
        echo "  1) $(msg settings_default)"
        echo "  2) $(msg settings_custom)"
        echo "  3) $(msg settings_later)"
        echo ""
        echo "============================================"
        read -p "  Chon [1-3]: " choice
        case "$choice" in
            1)
                AUTO_DETECT="true" AUTO_CRONTAB="true" AUTO_UPDATE_HOST="true"
                AUTO_UPDATE_LXC="true" AUTO_BACKUP="true" AUTO_HEALTH="true"
                save_config
                if ! crontab -l 2>/dev/null | grep -q "smart-update"; then
                    (crontab -l 2>/dev/null; echo "0 0 * * 1 /usr/local/bin/smart-update >>/var/log/smart-update.log 2>&1") | crontab -
                fi
                detect_services
                echo "" && echo "$(msg setup_done)"
                read -p "$(msg enter_continue)"
                return
                ;;
            2)
                echo ""
                for opt in AUTO_DETECT AUTO_CRONTAB AUTO_UPDATE_HOST AUTO_UPDATE_LXC AUTO_BACKUP AUTO_HEALTH; do
                    read -p "${opt}? (y/N): " ans
                    eval "${opt}=\$([[ \"\$ans\" == \"y\" || \"\$ans\" == \"Y\" ]] && echo \"true\" || echo \"false\")"
                done
                save_config
                [[ "$AUTO_CRONTAB" == "true" ]] && ! crontab -l 2>/dev/null | grep -q "smart-update" && (crontab -l 2>/dev/null; echo "0 0 * * 1 /usr/local/bin/smart-update >>/var/log/smart-update.log 2>&1") | crontab -
                [[ "$AUTO_DETECT" == "true" ]] && detect_services
                echo "" && echo "$(msg setup_done)"
                read -p "$(msg enter_continue)"
                return
                ;;
            3) return ;;
        esac
    done
}

# ============================================================
# MAIN MENU
# ============================================================

show_menu() {
    while true; do
        clear
        echo "============================================"
        echo "  $(msg title)"
        echo "============================================"
        echo ""
        echo "  $(msg opt_full)"
        echo "  $(msg opt_host)"
        echo "  $(msg opt_lxc)"
        echo "  $(msg opt_services)"
        echo "  $(msg opt_add)"
        echo "  $(msg opt_remove)"
        echo "  $(msg opt_health)"
        echo "  $(msg opt_backup)"
        echo "  $(msg opt_dryrun)"
        echo "  $(msg opt_log)"
        echo "  $(msg opt_check)"
        echo "  $(msg opt_update_script)"
        echo "  $(msg opt_settings)"
        echo "  $(msg opt_exit)"
        echo ""
        echo "============================================"
        read -p "  Chon [0-13]: " choice
        case "$choice" in
            1) # Full update
                echo -e "\n$(msg confirm)"
                read -p "  " confirm
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    [[ "$AUTO_BACKUP" == "true" ]] && backup_all
                    log "=========================================="
                    log "Smart Update Started"
                    log "=========================================="
                    update_host
                    for container in $(pct list | awk '{if(NR>1) print $1}'); do
                        update_container "$container" || true
                    done
                    log "=========================================="
                    log "Smart Update Completed"
                    log "=========================================="
                    echo -e "\n$(msg done)"
                    read -p "$(msg enter_continue)"
                fi
                ;;
            2) # Host only
                echo -e "\n$(msg confirm)"
                read -p "  " confirm
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    log "=== Host Update ==="
                    update_host
                    echo -e "\n$(msg done)"
                    read -p "$(msg enter_continue)"
                fi
                ;;
            3) # LXC only
                echo -e "\n$(msg confirm)"
                read -p "  " confirm
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    [[ "$AUTO_BACKUP" == "true" ]] && backup_all
                    log "=== LXC Update ==="
                    for container in $(pct list | awk '{if(NR>1) print $1}'); do
                        update_container "$container" || true
                    done
                    echo -e "\n$(msg done)"
                    read -p "$(msg enter_continue)"
                fi
                ;;
            4) cmd_list; read -p "$(msg enter_continue)" ;;
            5) # Add service
                echo ""
                read -p "Container ID: " ct_id; [[ -z "$ct_id" ]] && continue
                read -p "Service name: " service; [[ -z "$service" ]] && continue
                read -p "Update command: " cmd; [[ -z "$cmd" ]] && continue
                cmd_add "$ct_id" "$service" "$cmd"
                read -p "$(msg enter_continue)"
                ;;
            6) # Remove service
                echo ""
                read -p "Container ID: " ct_id; [[ -z "$ct_id" ]] && continue
                read -p "Service name: " service; [[ -z "$service" ]] && continue
                cmd_remove "$ct_id" "$service"
                read -p "$(msg enter_continue)"
                ;;
            7) health_check; read -p "$(msg enter_continue)" ;;
            8) backup_all; read -p "$(msg enter_continue)" ;;
            9) dryrun_update; read -p "$(msg enter_continue)" ;;
            10) # View log
                echo -e "\n=== Log ==="
                [[ -f "$LOG_FILE" ]] && tail -30 "$LOG_FILE" || echo "  No log"
                read -p "$(msg enter_continue)"
                ;;
            11) # Check updates
                echo -e "\n=== Updates ==="
                local host_updates
                host_updates=$(apt list --upgradable 2>/dev/null | grep -c "upgradable" || true)
                echo "  HOST: ${host_updates} packages"
                echo ""
                for container in $(pct list | awk '{if(NR>1) print $1}'); do
                    local name os
                    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
                    os=$(pct config "$container" | awk '/^ostype/ {print $2}')
                    echo "  CT ${container} (${name}) [${os}]"
                done
                read -p "$(msg enter_continue)"
                ;;
            12) update_script; read -p "$(msg enter_continue)" ;;
            13) show_settings ;;
            0) echo -e "\n$(msg exit_msg)"; exit 0 ;;
            *) echo -e "\n$(msg invalid)"; sleep 1 ;;
        esac
    done
}

# ============================================================
# FIRST RUN
# ============================================================

first_run() {
    [[ -f "$FIRST_RUN" ]] && return 0
    clear
    echo "============================================"
    echo "  $(msg welcome)"
    echo "============================================"
    echo ""
    echo "  $(msg select_lang)"
    echo ""
    echo "  $(msg lang_vi)"
    echo "  $(msg lang_en)"
    echo ""
    echo "============================================"
    read -p "  Chon [1-2]: " lang_choice
    case "$lang_choice" in
        1) save_language "vi" ;;
        2) save_language "en" ;;
        *) save_language "vi" ;;
    esac
    mkdir -p "$CONF_DIR"
    show_settings
    touch "$FIRST_RUN"
}

# ============================================================
# INIT
# ============================================================

mkdir -p "$CONF_DIR"
load_language
load_config
ensure_permissions

[[ ! -f "$SERVICES_FILE" ]] && cat > "$SERVICES_FILE" << 'CONF'
# Smart Update - Service Update Commands
# Format: CONTAINER_ID|SERVICE_NAME|UPDATE_COMMAND
CONF
chmod 600 "$SERVICES_FILE" 2>/dev/null

# ============================================================
# MAIN
# ============================================================

case "${1:-}" in
    --version|-v) echo "smart-update v${VERSION}"; exit 0 ;;
    --list|-l) load_language; cmd_list; exit 0 ;;
    --add|-a) load_language; cmd_add "${2:-}" "${3:-}" "${4:-}"; exit 0 ;;
    --remove|-r) load_language; cmd_remove "${2:-}" "${3:-}"; exit 0 ;;
    --detect) load_language; detect_services; exit 0 ;;
    --health) load_language; health_check; exit 0 ;;
    --backup) load_language; backup_all; exit 0 ;;
    --dryrun) DRY_RUN=true; load_language; dryrun_update; exit 0 ;;
    --update-script) load_language; update_script; exit 0 ;;
    --lang) save_language "${2:-vi}"; echo "Language: ${2:-vi}"; exit 0 ;;
    --help|-h)
        cat << HELP
Smart Update Manager v${VERSION}

Usage: smart-update [OPTIONS]

Options:
  (none)          Interactive menu
  --version, -v   Show version
  --list, -l      List services
  --add, -a       Add service
  --remove, -r    Remove service
  --detect        Auto-detect services
  --health        System health check
  --backup        Backup LXC containers
  --dryrun        Dry run (no actual update)
  --update-script Update script from GitHub
  --lang [vi|en]  Set language
  --help, -h      Show help
HELP
        exit 0
        ;;
esac

if [[ $# -eq 0 ]]; then
    first_run
    show_menu
    exit 0
fi
