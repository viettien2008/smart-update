# ============================================================
# CONFIG
# ============================================================

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
    AUTO_DETECT=${AUTO_DETECT:-"true"}
    AUTO_CRONTAB=${AUTO_CRONTAB:-"true"}
    AUTO_UPDATE_HOST=${AUTO_UPDATE_HOST:-"true"}
    AUTO_UPDATE_LXC=${AUTO_UPDATE_LXC:-"true"}
}

save_config() {
    cat > "$CONFIG_FILE" << CONF
# Smart Update Config
AUTO_DETECT=${AUTO_DETECT}
AUTO_CRONTAB=${AUTO_CRONTAB}
AUTO_UPDATE_HOST=${AUTO_UPDATE_HOST}
AUTO_UPDATE_LXC=${AUTO_UPDATE_LXC}
CONF
}

# ============================================================
# PERMISSIONS
# ============================================================

ensure_permissions() {
    if [[ -f "$SERVICES_FILE" ]]; then
        chmod 600 "$SERVICES_FILE" 2>/dev/null || true
    fi
    if [[ -f "$CONFIG_FILE" ]]; then
        chmod 600 "$CONFIG_FILE" 2>/dev/null || true
    fi
}

validate_input() {
    local input="$1"
    if ! echo "$input" | grep -qE "^[a-zA-Z0-9._/| =-]+$"; then
        return 1
    fi
    return 0
}

# ============================================================
# LOGGING
# ============================================================

log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo -e "$msg" | tee -a "$LOG_FILE"
}

log_info() { log "[INFO] $1"; }
log_ok() { log "[OK] $1"; }
log_warn() { log "[WARN] $1"; }
log_error() { log "[ERROR] $1"; }

# ============================================================
# SERVICE MANAGEMENT
# ============================================================

cmd_list() {
    echo -e "\n=== Service Update Entries ==="
    if [[ -f "$SERVICES_FILE" ]]; then
        local count=0
        while IFS='|' read -r ct_id service cmd; do
            [[ "$ct_id" =~ ^#.*$ || -z "$ct_id" ]] && continue
            echo "  CT ${ct_id} | ${service} | ${cmd}"
            count=$((count + 1))
        done < "$SERVICES_FILE"
        echo -e "\nTotal: ${count} entries"
    else
        echo "  No services.conf found"
    fi
}

cmd_add() {
    local ct_id="$1"
    local service="$2"
    local cmd="$3"

    if [[ -z "$ct_id" || -z "$service" || -z "$cmd" ]]; then
        echo "Usage: smart-update --add <CT_ID> <SERVICE_NAME> \"<UPDATE_COMMAND>\""
        exit 1
    fi

    validate_input "$ct_id" || { echo "Invalid Container ID"; exit 1; }
    validate_input "$service" || { echo "Invalid service name"; exit 1; }

    [[ -f "$SERVICES_FILE" ]] && sed -i "/^${ct_id}|${service}|/d" "$SERVICES_FILE"
    echo "${ct_id}|${service}|${cmd}" >> "$SERVICES_FILE"
    chmod 600 "$SERVICES_FILE"
    echo "$(msg added) CT ${ct_id} | ${service}"
}

cmd_remove() {
    local ct_id="$1"
    local service="$2"

    if [[ -z "$ct_id" || -z "$service" ]]; then
        echo "Usage: smart-update --remove <CT_ID> <SERVICE_NAME>"
        exit 1
    fi

    if [[ -f "$SERVICES_FILE" ]]; then
        sed -i "/^${ct_id}|${service}|/d" "$SERVICES_FILE"
        echo "$(msg removed) CT ${ct_id} | ${service}"
    fi
}

# ============================================================
# AUTO DETECT SERVICES
# ============================================================

detect_services() {
    local count=0
    echo "$(msg detect_title)"
    echo ""

    for container in $(pct list 2>/dev/null | awk '{if(NR>1) print $1}'); do
        local name os
        name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
        os=$(pct config "$container" 2>/dev/null | awk '/^ostype/ {print $2}')

        echo "CT ${container} (${name}) [${os}]"

        # Detect services
        local services
        services=$(pct exec "$container" -- systemctl list-units --type=service --state=running --no-pager 2>/dev/null | grep -v "getty\|journald\|Network\|dbus\|rsyslog\|systemd-logind\|crond\|networkd\|logind\|user@" | awk '{print $1}' | sed 's/.service//' || true)

        for svc in $services; do
            # Skip system services
            [[ "$svc" =~ ^(ssh|postfix|cron|rsyslog)$ ]] && continue

            # Check if already configured
            if grep -q "^${container}|${svc}|" "$SERVICES_FILE" 2>/dev/null; then
                echo "  - ${svc} (already configured)"
                continue
            fi

            # Auto-generate update command based on OS
            local update_cmd=""
            case "$os" in
                alma|centos|fedora|rocky)
                    update_cmd="pct exec ${container} -- dnf update -y ${svc}"
                    ;;
                ubuntu|debian|devuan)
                    update_cmd="pct exec ${container} -- apt update && apt upgrade -y ${svc}"
                    ;;
                alpine)
                    update_cmd="pct exec ${container} -- apk update && apk upgrade ${svc}"
                    ;;
            esac

            if [[ -n "$update_cmd" ]]; then
                echo "  + ${svc} (NEW)"
                echo "${container}|${svc}|${update_cmd}" >> "$SERVICES_FILE"
                count=$((count + 1))
            fi
        done
        echo ""
    done

    chmod 600 "$SERVICES_FILE" 2>/dev/null || true
    echo "$(msg detected) ${count} services"
}

# ============================================================
# UPDATE FUNCTIONS
# ============================================================

update_host() {
    log_info "=== Updating PVE Host ==="
    local updates
    updates=$(apt list --upgradable 2>/dev/null | grep -c "upgradable" || true)
    if [[ "$updates" -eq 0 ]]; then
        log_ok "Host: No updates available"
        return 0
    fi
    log_info "Host: ${updates} packages to update"
    if apt-get update -qq && apt-get upgrade -y -qq >> "$LOG_FILE" 2>&1; then
        log_ok "Host: Update completed"
    else
        log_error "Host: Update failed"
        return 1
    fi
    [[ -f /var/run/reboot-required ]] && log_warn "Host: Reboot required"
    apt-get autoremove -y -qq >> "$LOG_FILE" 2>&1 || true
    apt-get autoclean -qq >> "$LOG_FILE" 2>&1 || true
}

update_container_os() {
    local container=$1
    local name os
    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
    os=$(pct config "$container" | awk '/^ostype/ {print $2}')
    log_info "CT ${container} (${name}): Updating OS..."

    case "$os" in
    alpine) pct exec "$container" -- ash -c "apk update && apk upgrade" >> "$LOG_FILE" 2>&1 ;;
    archlinux) pct exec "$container" -- bash -c "pacman -Syyu --noconfirm" >> "$LOG_FILE" 2>&1 ;;
    fedora|rocky|centos|alma) pct exec "$container" -- bash -c "dnf -y update && dnf -y upgrade" >> "$LOG_FILE" 2>&1 ;;
    ubuntu|debian|devuan)
        pct exec "$container" -- bash -c "apt-get update && DEBIAN_FRONTEND=noninteractive apt-get -o Dpkg::Options::='--force-confold' dist-upgrade -y" >> "$LOG_FILE" 2>&1
        pct exec "$container" -- bash -c "rm -rf /usr/lib/python3.*/EXTERNALLY-MANAGED" 2>/dev/null || true
        ;;
    opensuse) pct exec "$container" -- bash -c "zypper ref && zypper --non-interactive dup" >> "$LOG_FILE" 2>&1 ;;
    *) log_warn "CT ${container}: Unknown OS '${os}'"; return 1 ;;
    esac

    case "$os" in
    ubuntu|debian|devuan) pct exec "$container" -- bash -c "apt-get autoremove -y && apt-get autoclean" >> "$LOG_FILE" 2>&1 || true ;;
    fedora|rocky|centos|alma) pct exec "$container" -- bash -c "dnf autoremove -y && dnf clean all" >> "$LOG_FILE" 2>&1 || true ;;
    esac
}

update_container_services() {
    local container=$1
    [[ ! -f "$SERVICES_FILE" ]] && return 0
    local entries
    entries=$(grep -v '^#' "$SERVICES_FILE" | grep -v '^$' | grep "^${container}|" || true)
    [[ -z "$entries" ]] && return 0
    while IFS='|' read -r ct_id service cmd; do
        if [[ "$ct_id" == "$container" ]]; then
            log_info "CT ${container}: Updating '${service}'..."
            if eval "$cmd" >> "$LOG_FILE" 2>&1; then
                log_ok "CT ${container}: '${service}' updated"
            else
                log_error "CT ${container}: '${service}' update failed"
            fi
        fi
    done <<< "$entries"
}

update_container() {
    local container=$1
    local name
    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
    log_info "=== CT ${container} (${name}) ==="

    if pct config "$container" 2>/dev/null | grep -q "^template:"; then
        log_warn "CT ${container}: Skipping template"
        return 0
    fi

    local status
    status=$(pct status "$container" 2>/dev/null || echo "status: unknown")
    if [[ "$status" == "status: stopped" ]]; then
        log_info "CT ${container}: Starting..."
        pct start "$container" >> "$LOG_FILE" 2>&1
        sleep 5
    fi

    update_container_os "$container" || true
    update_container_services "$container"
}

# ============================================================
# SETTINGS MENU
# ============================================================

show_settings() {
    while true; do
        clear
        echo "============================================"
        echo "  $(msg settings_title)"
        echo "============================================"
        echo ""
        echo "  1) $(msg settings_default)"
        echo "  2) $(msg settings_custom)"
        echo "  3) $(msg settings_later)"
        echo ""
        echo "============================================"
        read -p "  Chon [1-3]: " choice

        case "$choice" in
            1)
                AUTO_DETECT="true"
                AUTO_CRONTAB="true"
                AUTO_UPDATE_HOST="true"
                AUTO_UPDATE_LXC="true"
                save_config

                # Setup crontab
                echo "$(msg setup_crontab)"
                if ! crontab -l 2>/dev/null | grep -q "smart-update"; then
                    (crontab -l 2>/dev/null; echo "0 0 * * 1 /usr/local/bin/smart-update >>/var/log/smart-update.log 2>&1") | crontab -
                fi

                # Auto detect services
                detect_services

                echo ""
                echo "$(msg setup_done)"
                read -p "$(msg enter_continue)"
                return
                ;;
            2)
                # Custom settings
                echo ""
                read -p "Auto-detect services? (y/N): " ans
                AUTO_DETECT=$([[ "$ans" == "y" || "$ans" == "Y" ]] && echo "true" || echo "false")

                read -p "Setup crontab (Monday 00:00)? (y/N): " ans
                AUTO_CRONTAB=$([[ "$ans" == "y" || "$ans" == "Y" ]] && echo "true" || echo "false")

                read -p "Auto-update Host? (y/N): " ans
                AUTO_UPDATE_HOST=$([[ "$ans" == "y" || "$ans" == "Y" ]] && echo "true" || echo "false")

                read -p "Auto-update LXC? (y/N): " ans
                AUTO_UPDATE_LXC=$([[ "$ans" == "y" || "$ans" == "Y" ]] && echo "true" || echo "false")

                save_config

                # Setup crontab if enabled
                if [[ "$AUTO_CRONTAB" == "true" ]]; then
                    echo "$(msg setup_crontab)"
                    if ! crontab -l 2>/dev/null | grep -q "smart-update"; then
                        (crontab -l 2>/dev/null; echo "0 0 * * 1 /usr/local/bin/smart-update >>/var/log/smart-update.log 2>&1") | crontab -
                    fi
                fi

                # Auto detect if enabled
                if [[ "$AUTO_DETECT" == "true" ]]; then
                    detect_services
                fi

                echo ""
                echo "$(msg setup_done)"
                read -p "$(msg enter_continue)"
                return
                ;;
            3)
                return
                ;;
        esac
    done
}

# ============================================================
# MAIN MENU
# ============================================================

show_menu() {
    while true; do
        clear
        echo "============================================"
        echo "  $(msg title) v${VERSION}"
        echo "============================================"
        echo ""
        echo "  $(msg opt_full)"
        echo "  $(msg opt_host)"
        echo "  $(msg opt_lxc)"
        echo "  $(msg opt_services)"
        echo "  $(msg opt_add)"
        echo "  $(msg opt_remove)"
        echo "  $(msg opt_log)"
        echo "  $(msg opt_check)"
        echo "  $(msg opt_settings)"
        echo "  $(msg opt_exit)"
        echo ""
        echo "============================================"
        read -p "  Chon [0-9]: " choice

        case "$choice" in
            1)
                echo -e "\n$(msg confirm)"
                read -p "  " confirm
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    log "=========================================="
                    log "Smart Update Started"
                    log "=========================================="
                    update_host
                    for container in $(pct list | awk '{if(NR>1) print $1}'); do
                        update_container "$container" || true
                    done
                    log "=========================================="
                    log "Smart Update Completed"
                    log "=========================================="
                    echo -e "\n$(msg done)"
                    read -p "$(msg enter_continue)"
                fi
                ;;
            2)
                echo -e "\n$(msg confirm)"
                read -p "  " confirm
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    log "=========================================="
                    log "Host Update Started"
                    log "=========================================="
                    update_host
                    log "=========================================="
                    log "Host Update Completed"
                    log "=========================================="
                    echo -e "\n$(msg done)"
                    read -p "$(msg enter_continue)"
                fi
                ;;
            3)
                echo -e "\n$(msg confirm)"
                read -p "  " confirm
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    log "=========================================="
                    log "LXC Update Started"
                    log "=========================================="
                    for container in $(pct list | awk '{if(NR>1) print $1}'); do
                        update_container "$container" || true
                    done
                    log "=========================================="
                    log "LXC Update Completed"
                    log "=========================================="
                    echo -e "\n$(msg done)"
                    read -p "$(msg enter_continue)"
                fi
                ;;
            4)
                cmd_list
                read -p "$(msg enter_continue)"
                ;;
            5)
                echo ""
                read -p "$(msg input_ct_id) " ct_id
                [[ -z "$ct_id" ]] && continue
                read -p "$(msg input_service) " service
                [[ -z "$service" ]] && continue
                read -p "$(msg input_cmd) " cmd
                [[ -z "$cmd" ]] && continue
                cmd_add "$ct_id" "$service" "$cmd"
                read -p "$(msg enter_continue)"
                ;;
            6)
                echo ""
                read -p "$(msg input_id) " ct_id
                [[ -z "$ct_id" ]] && continue
                read -p "$(msg input_service) " service
                [[ -z "$service" ]] && continue
                cmd_remove "$ct_id" "$service"
                read -p "$(msg enter_continue)"
                ;;
            7)
                echo -e "\n=== $(msg log_title) ==="
                if [[ -f "$LOG_FILE" ]]; then
                    tail -30 "$LOG_FILE"
                else
                    echo "  $(msg no_log)"
                fi
                read -p "$(msg enter_continue)"
                ;;
            8)
                echo -e "\n=== Check Updates ==="
                local host_updates
                host_updates=$(apt list --upgradable 2>/dev/null | grep -c "upgradable" || true)
                echo "  HOST: ${host_updates} $(msg host_updates)"
                echo ""
                echo "  $(msg lxc_containers)"
                for container in $(pct list | awk '{if(NR>1) print $1}'); do
                    local name os
                    name=$(pct exec "$container" hostname 2>/dev/null || echo "unknown")
                    os=$(pct config "$container" | awk '/^ostype/ {print $2}')
                    echo "    CT ${container} (${name}) [${os}]"
                done
                read -p "$(msg enter_continue)"
                ;;
            9)
                show_settings
                ;;
            0)
                echo -e "\n$(msg exit_msg)"
                exit 0
                ;;
            *)
                echo -e "\n$(msg invalid)"
                sleep 1
                ;;
        esac
    done
}

# ============================================================
# FIRST RUN
# ============================================================

first_run() {
    if [[ -f "$FIRST_RUN" ]]; then
        return 0
    fi

    clear
    echo "============================================"
    echo "  $(msg welcome)"
    echo "============================================"
    echo ""
    echo "  $(msg select_lang)"
    echo ""
    echo "  $(msg lang_vi)"
    echo "  $(msg lang_en)"
    echo ""
    echo "============================================"
    read -p "  Chon [1-2]: " lang_choice

    case "$lang_choice" in
        1) save_language "vi" ;;
        2) save_language "en" ;;
        *) save_language "vi" ;;
    esac

    # Setup config
    mkdir -p "$CONF_DIR"

    # First run setup
    show_settings

    # Mark first run complete
    touch "$FIRST_RUN"
}

# ============================================================
# INIT
# ============================================================

mkdir -p "$CONF_DIR"
load_language
load_config
ensure_permissions

# Initialize services.conf
if [[ ! -f "$SERVICES_FILE" ]]; then
    cat > "$SERVICES_FILE" << 'CONF'
# Smart Update - Service Update Commands
# Format: CONTAINER_ID|SERVICE_NAME|UPDATE_COMMAND
CONF
    chmod 600 "$SERVICES_FILE"
fi

# ============================================================
# MAIN
# ============================================================

case "${1:-}" in
    --version|-v) echo "smart-update v${VERSION}"; exit 0 ;;
    --list|-l) load_language; cmd_list; exit 0 ;;
    --add|-a) load_language; cmd_add "${2:-}" "${3:-}" "${4:-}"; exit 0 ;;
    --remove|-r) load_language; cmd_remove "${2:-}" "${3:-}"; exit 0 ;;
    --detect) load_language; detect_services; exit 0 ;;
    --lang) save_language "${2:-vi}"; echo "Language set to: ${2:-vi}"; exit 0 ;;
    --help|-h)
        echo "Smart Update Manager v${VERSION}"
        echo ""
        echo "Usage: smart-update [OPTIONS]"
        echo ""
        echo "Options:"
        echo "  (none)          Interactive menu"
        echo "  --version, -v   Show version"
        echo "  --list, -l      List services"
        echo "  --add, -a       Add service"
        echo "  --remove, -r    Remove service"
        echo "  --detect        Auto-detect services"
        echo "  --lang [vi|en]  Set language"
        echo "  --help, -h      Show help"
        exit 0
        ;;
esac

# First run check
if [[ $# -eq 0 ]]; then
    first_run
    show_menu
    exit 0
fi
